generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id          String      @id @default(cuid())
  roomId      String      @map("room_id")
  items       Json
  status      OrderStatus @default(pending)
  aiReadyFlag Boolean     @default(false) @map("ai_ready_flag")
  createdAt   DateTime    @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("orders")
}

model MenuItem {
  id        String   @id @default(cuid())
  name      String   @unique
  nameZh    String?  @map("name_zh")
  nameEn    String?  @map("name_en")
  nameHant  String?  @map("name_hant")
  descZh    String?  @map("desc_zh")
  descEn    String?  @map("desc_en")
  descHant  String?  @map("desc_hant")
  imageUrl  String?  @map("image_url")
  category  String
  stock     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  serviceCounterId String? @map("service_counter_id")
  serviceCounter   ServiceCounter? @relation(fields: [serviceCounterId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("menu_items")
}

model Category {
  id              String          @id @default(cuid())
  name            String          @unique
  nameZh          String?         @map("name_zh")
  nameEn          String?         @map("name_en")
  nameHant        String?         @map("name_hant")
  imageUrl        String?         @map("image_url")
  serviceCounterId String?        @map("service_counter_id")
  serviceCounter  ServiceCounter? @relation(fields: [serviceCounterId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt       DateTime        @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("categories")
}

model ServiceCounter {
  id        String   @id @default(cuid())
  name      String   @unique
  nameZh    String?  @map("name_zh")
  nameEn    String?  @map("name_en")
  nameHant  String?  @map("name_hant")
  menuItems MenuItem[]
  categories Category[]
  createdAt DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("service_counters")
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("rooms")
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("admin_users")
}

model SystemConfig {
  key       String   @id @map("key")
  value     String   @map("value")
  createdAt DateTime @default(now()) @db.Timestamptz(3) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz(3) @map("updated_at")

  @@map("system_configs")
}

enum OrderStatus {
  pending
  completed
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}
