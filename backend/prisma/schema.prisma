generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  suspended
  offboarded
}

enum UserRole {
  SUPER_ADMIN
  CUSTOMER_ADMIN
  OPERATOR
}

enum UserStatus {
  invited
  active
  disabled
}

enum OrderStatus {
  pending
  acknowledged
  done
}

enum RoomSessionStatus {
  occupied
  vacant
}

enum CategoryOrderMode {
  quantity
  one_off
}

enum CategoryLimitMode {
  total_per_category
  per_item
}

enum LicenseAuditChangeType {
  create
  renew
  add_rooms
  suspend
  activate
  offboard
}

enum InviteStatus {
  pending
  activated
  expired
  revoked
}

model Tenant {
  id                      String                   @id @default(cuid())
  name                    String
  status                  TenantStatus             @default(active)
  licenseExpiry           DateTime                 @map("license_expiry") @db.Timestamptz(3)
  timezone                String                   @default("Asia/Hong_Kong")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  sites                   Site[]
  licenses                License[]
  users                   User[]
  rooms                   Room[]
  menuCategories          MenuCategory[]
  menuItems               MenuItem[]
  orders                  Order[]
  roomSessions            RoomSession[]
  licenseAudit            LicenseAuditLog[]
  configs                 TenantConfig[]
  invites                 Invite[]
  siteBrandings           SiteBranding[]
  roomOperatorAssignments RoomOperatorAssignment[]

  @@map("tenants")
}

model TenantConfig {
  tenantId  String   @map("tenant_id")
  key       String
  value     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, key])
  @@index([tenantId])
  @@map("tenant_configs")
}

model License {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  siteId     String?  @unique @map("site_id")
  plan       String   @default("standard")
  roomLimit  Int      @default(10) @map("room_limit")
  expiryDate DateTime @map("expiry_date") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site       Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("licenses")
}

model LicenseAuditLog {
  id         String                 @id @default(cuid())
  tenantId   String                 @map("tenant_id")
  changedBy  String                 @map("changed_by")
  changeType LicenseAuditChangeType @map("change_type")
  oldValue   Json?                  @map("old_value")
  newValue   Json?                  @map("new_value")
  changedAt  DateTime               @default(now()) @map("changed_at") @db.Timestamptz(3)
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, changedAt])
  @@map("license_audit_log")
}

model Site {
  id                      String                   @id @default(cuid())
  tenantId                String                   @map("tenant_id")
  name                    String
  address                 String?
  alertTimeoutSec         Int                      @default(60) @map("alert_timeout_sec")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branding                SiteBranding?
  license                 License?
  rooms                   Room[]
  menuCategories          MenuCategory[]
  menuItems               MenuItem[]
  orders                  Order[]
  roomSessions            RoomSession[]
  roomOperatorAssignments RoomOperatorAssignment[]
  userSiteAssignments     UserSiteAssignment[]

  @@index([tenantId])
  @@map("sites")
}

model SiteBranding {
  id                    String   @id @default(cuid())
  tenantId              String   @map("tenant_id")
  siteId                String   @unique @map("site_id")
  logoUrl               String?  @map("logo_url")
  backgroundUrl         String?  @map("background_url")
  primaryColour         String   @default("#00845C") @map("primary_colour")
  welcomeEn             String?  @map("welcome_en")
  welcomeTc             String?  @map("welcome_tc")
  welcomeSc             String?  @map("welcome_sc")
  wifiSsid              String?  @map("wifi_ssid")
  wifiPasswordEncrypted Bytes?   @map("wifi_password_encrypted")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site                  Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("site_branding")
}

model Room {
  id                  String                   @id @default(cuid())
  tenantId            String                   @map("tenant_id")
  siteId              String                   @map("site_id")
  code                String?
  roomToken           String                   @unique @default(cuid()) @map("room_token")
  name                String
  nameEn              String?                  @map("name_en")
  nameTc              String?                  @map("name_tc")
  nameSc              String?                  @map("name_sc")
  menuId              String?                  @map("menu_id")
  createdAt           DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant              Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site                Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sessions            RoomSession[]
  orders              Order[]
  operatorAssignments RoomOperatorAssignment[]

  @@unique([siteId, code])
  @@index([tenantId])
  @@map("rooms")
}

model RoomSession {
  id        String                 @id @default(cuid())
  tenantId  String                 @map("tenant_id")
  siteId    String                 @map("site_id")
  roomId    String                 @map("room_id")
  headcount Int
  status    RoomSessionStatus      @default(occupied)
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  resetAt   DateTime?              @map("reset_at") @db.Timestamptz(3)
  resetBy   String?                @map("reset_by")
  closedAt  DateTime?              @map("closed_at") @db.Timestamptz(3)
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site      Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  room      Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  usages    SessionCategoryUsage[]
  orders    Order[]

  @@index([roomId, status])
  @@index([siteId, createdAt])
  @@map("room_sessions")
}

model SessionCategoryUsage {
  id           String       @id @default(cuid())
  sessionId    String       @map("session_id")
  roomId       String       @map("room_id")
  categoryId   String       @map("category_id")
  itemId       String?      @map("item_id")
  quantityUsed Int          @default(0) @map("quantity_used")
  session      RoomSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  item         MenuItem?    @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@unique([sessionId, categoryId, itemId])
  @@index([sessionId])
  @@map("session_category_usage")
}

model MenuCategory {
  id                String                 @id @default(cuid())
  tenantId          String                 @map("tenant_id")
  siteId            String                 @map("site_id")
  key               String
  nameEn            String?                @map("name_en")
  nameTc            String?                @map("name_tc")
  nameSc            String?                @map("name_sc")
  imageUrl          String?                @map("image_url")
  orderMode         CategoryOrderMode      @default(quantity) @map("order_mode")
  limitMode         CategoryLimitMode      @default(total_per_category) @map("limit_mode")
  defaultOperatorId String?                @map("default_operator_id")
  sortOrder         Int                    @default(0) @map("sort_order")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site              Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  defaultOperator   User?                  @relation("CategoryDefaultOperator", fields: [defaultOperatorId], references: [id], onDelete: SetNull)
  items             MenuItem[]
  usages            SessionCategoryUsage[]

  @@unique([siteId, key])
  @@index([tenantId])
  @@map("menu_categories")
}

model MenuItem {
  id         String                 @id @default(cuid())
  tenantId   String                 @map("tenant_id")
  siteId     String                 @map("site_id")
  categoryId String                 @map("category_id")
  roomId     String?                @map("room_id")
  key        String
  nameEn     String?                @map("name_en")
  nameTc     String?                @map("name_tc")
  nameSc     String?                @map("name_sc")
  descEn     String?                @map("desc_en")
  descTc     String?                @map("desc_tc")
  descSc     String?                @map("desc_sc")
  imageUrl   String?                @map("image_url")
  stock      Int                    @default(0)
  isActive   Boolean                @default(true) @map("is_active")
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site       Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category   MenuCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  usages     SessionCategoryUsage[]

  @@unique([siteId, key])
  @@index([tenantId])
  @@map("menu_items")
}

model Order {
  id             String       @id @default(cuid())
  tenantId       String       @map("tenant_id")
  siteId         String       @map("site_id")
  roomId         String       @map("room_id")
  sessionId      String?      @map("session_id")
  items          Json
  status         OrderStatus  @default(pending)
  acknowledgedAt DateTime?    @map("acknowledged_at") @db.Timestamptz(3)
  acknowledgedBy String?      @map("acknowledged_by")
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz(3)
  completedBy    String?      @map("completed_by")
  aiReadyFlag    Boolean      @default(false) @map("ai_ready_flag")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site           Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  room           Room         @relation(fields: [roomId], references: [id], onDelete: Restrict)
  session        RoomSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  acker          User?        @relation("OrderAcker", fields: [acknowledgedBy], references: [id], onDelete: SetNull)
  doer           User?        @relation("OrderDoer", fields: [completedBy], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([sessionId])
  @@index([siteId, status, createdAt])
  @@map("orders")
}

model User {
  id                   String                   @id @default(cuid())
  tenantId             String?                  @map("tenant_id")
  email                String?                  @unique
  username             String?                  @unique
  passwordHash         String?                  @map("password_hash")
  ssoProvider          String?                  @map("sso_provider")
  role                 UserRole                 @default(OPERATOR)
  status               UserStatus               @default(invited)
  preferredLanguage    String                   @default("zh") @map("preferred_language")
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant               Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteAssignments      UserSiteAssignment[]
  operatorAssignments  RoomOperatorAssignment[]
  defaultForCategories MenuCategory[]           @relation("CategoryDefaultOperator")
  ordersAcked          Order[]                  @relation("OrderAcker")
  ordersDone           Order[]                  @relation("OrderDoer")
  refreshTokens        RefreshToken[]
  invitesSent          Invite[]                 @relation("InviteCreator")

  @@index([tenantId])
  @@map("users")
}

model UserSiteAssignment {
  userId    String   @map("user_id")
  siteId    String   @map("site_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@id([userId, siteId])
  @@map("user_site_assignments")
}

model RoomOperatorAssignment {
  id             String   @id @default(cuid())
  roomId         String   @map("room_id")
  operatorUserId String   @map("operator_user_id")
  siteId         String   @map("site_id")
  tenantId       String   @map("tenant_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  operator       User     @relation(fields: [operatorUserId], references: [id], onDelete: Cascade)
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([roomId, operatorUserId])
  @@index([tenantId])
  @@index([operatorUserId])
  @@index([siteId])
  @@map("room_operator_assignments")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  issuedAt   DateTime  @default(now()) @map("issued_at") @db.Timestamptz(3)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  revoked    Boolean   @default(false)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)
  replacedBy String?   @map("replaced_by")
  userAgent  String?   @map("user_agent")
  ip         String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked])
  @@map("refresh_tokens")
}

model Invite {
  id          String       @id @default(cuid())
  tenantId    String?      @map("tenant_id")
  email       String
  role        UserRole
  tokenHash   String       @unique @map("token_hash")
  expiresAt   DateTime     @map("expires_at") @db.Timestamptz(3)
  status      InviteStatus @default(pending)
  createdBy   String       @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  activatedAt DateTime?    @map("activated_at") @db.Timestamptz(3)
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator     User         @relation("InviteCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
  @@map("invites")
}

model SystemConfig {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("system_configs")
}
